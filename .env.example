# ─── Payload CMS ─────────────────────────────────────────────────────────────
PAYLOAD_SECRET=your-secret-here

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/time-and-again

# ─── Supabase Project ─────────────────────────────────────────────────────────
# Your Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co

# ─── Supabase Storage (S3-compatible) ────────────────────────────────────────
# Public base URL used to build media asset URLs returned by Payload.
# Format: https://<project-ref>.supabase.co/storage/v1
SUPABASE_STORAGE_URL=https://<project-ref>.supabase.co/storage/v1

# S3-compatible endpoint for the AWS SDK to send upload requests to.
# Format: https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_STORAGE_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3

# The Supabase storage bucket name (must be created in the Supabase dashboard).
SUPABASE_STORAGE_BUCKET=pieces

# Service-role credentials — available in Supabase dashboard under
# Project Settings > API > S3 Connection.
SUPABASE_ACCESS_KEY_ID=your-supabase-s3-access-key-id
SUPABASE_SECRET_ACCESS_KEY=your-supabase-s3-secret-access-key
